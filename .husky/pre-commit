#!/usr/bin/env sh
# Pre-commit: type-check + lint
# Catches issues locally before they reach CI.
# Skip with --no-verify for emergencies (CI will still catch violations).

set -e

echo "Pre-commit: type check..."
npm run type-check --workspaces --if-present

echo "Pre-commit: lint..."
npm run lint --workspaces --if-present

echo "Pre-commit: passed"
